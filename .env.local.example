# Copy this file to .env.local and fill in your EmailJS credentials.
# .env.local is gitignored — your keys never get committed.
#
# Setup steps:
#   1. Create a free account at https://www.emailjs.com
#   2. Add an Email Service (Gmail, Outlook, etc.) → copy the Service ID
#   3. Create an Email Template with these variables:
#        {{from_name}}   — sender's name
#        {{subject}}     — message subject
#        {{message}}     — message body
#      Set "To Email" to your personal address in the template settings.
#      Copy the Template ID.
#   4. Go to Account → API Keys → copy your Public Key
#   5. (Recommended) Set allowed domains to msaggu204.github.io in EmailJS dashboard
#
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
